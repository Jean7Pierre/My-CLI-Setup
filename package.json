{
  "name": "my-cli-setup",
  "version": "1.0.0",
  "description": "CLI para inicializar proyectos frontend",
  "main": "index.js",
  "bin": {
    "mi-cli": "./src/index.ts"
  },
  "scripts": {
    "dev": "tsx ./src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "docs:start": "cd docs-site && pnpm run start"
  },
  "keywords": [],
  "author": "Jean Pierre Ludena",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/figlet": "^1.5.8",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "26.1.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.7.0",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1"
  },
  "dependencies": {
    "@inquirer/prompts": "8.5.2",
    "boxen": "^8.0.1",
    "figlet": "^1.7.0",
    "gradient-string": "^2.0.2",
    "picocolors": "^1.0.1"
  }
}
